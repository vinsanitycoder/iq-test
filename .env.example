# Copy this file to .env.local and fill in your project values.

# ── Supabase ───────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (required for personality test invite emails) ───────────────
# Sign up at https://resend.com, verify your sending domain, then create an API key.
# RESEND_FROM_EMAIL must be a verified sender on your Resend domain.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@your-domain.com
